{
  "name": "little-acres",
  "private": true,
  "version": "0.0.1",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
    "preview": "vite preview",
    "lint": "eslint . && prettier --check .",
    "pack:atlas": "node tools/gen-shadow-placements.mjs && node tools/pack-atlas.mjs",
    "pack:icons": "node tools/pack-icons.mjs",
    "shadow:gen": "node tools/gen-shadow-placements.mjs",
    "shadow:new": "node tools/shadow-new.mjs",
    "shadow:validate": "node tools/shadow-validate.mjs",
    "shadow:shift": "node tools/shadow-shift.mjs",
    "shadow:capture": "node tools/shadow-capture.mjs",
    "format": "prettier --write .",
    "test": "vitest run"
  },
  "dependencies": {
    "phaser": "^3.90.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "eslint": "^10.6.0",
    "eslint-config-prettier": "^10.1.8",
    "globals": "^17.7.0",
    "jimp": "^1.6.1",
    "prettier": "^3.9.4",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.63.0",
    "vite": "^8.1.3",
    "vite-plugin-pwa": "^1.3.0",
    "vitest": "^4.1.10"
  }
}
